{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: w64devkit build",
            "command": "C:/raylib/w64devkit/bin/g++.exe", 
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-I", "C:/raylib/w64devkit/x86_64-w64-mingw32/include",
                "-L", "C:/raylib/w64devkit/x86_64-w64-mingw32/lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm"
            ],
            "options": {
                "cwd": "C:/raylib/w64devkit/bin"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}